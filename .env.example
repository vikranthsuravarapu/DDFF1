# Environment variables for DDFF
# Copy this file to .env and fill in the values.
# These variables are also used by docker-compose.yml.

# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
APP_URL="MY_APP_URL"

# JWT Secret
JWT_SECRET="generate-strong-random-secret-minimum-32-characters"

# Google Maps
VITE_GOOGLE_MAPS_API_KEY="YOUR_GOOGLE_MAPS_API_KEY"

# Google OAuth
GOOGLE_CLIENT_ID="MY_GOOGLE_CLIENT_ID"
GOOGLE_CLIENT_SECRET="MY_GOOGLE_CLIENT_SECRET"

# Database URL (PostgreSQL)
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# Razorpay
RAZORPAY_KEY_ID="rzp_test_..."
RAZORPAY_KEY_SECRET="your_secret_..."
RAZORPAY_WEBHOOK_SECRET="your_razorpay_webhook_secret"

# Twilio
TWILIO_ACCOUNT_SID="AC..."
TWILIO_AUTH_TOKEN="your_auth_token..."
TWILIO_WHATSAPP_FROM="whatsapp:+14155238886"

# Support
VITE_SUPPORT_WHATSAPP="919XXXXXXXXX"
ADMIN_PHONE="+91XXXXXXXXXX"

# Port
PORT=8080

# Google Cloud Storage
GCS_BUCKET_NAME=ddff-uploads
GOOGLE_CLOUD_PROJECT=your-gcp-project-id

# Sentry
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
